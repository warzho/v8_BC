<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:drools="http://www.jboss.org/drools"
                   id="Definition"
                   targetNamespace="http://www.jboss.org/drools">

  <bpmn2:process id="fraud-investigation"
                 drools:packageName="com.ibm.bamoe.demo"
                 drools:version="1.0.0"
                 drools:adHoc="false"
                 name="Fraud Investigation"
                 isExecutable="true"
                 processType="Public">

    <!-- Process Variables -->
    <bpmn2:property id="caseId" itemSubjectRef="ItemDefinition_String" name="caseId"/>
    <bpmn2:property id="customerId" itemSubjectRef="ItemDefinition_String" name="customerId"/>
    <bpmn2:property id="transactionId" itemSubjectRef="ItemDefinition_String" name="transactionId"/>
    <bpmn2:property id="suspiciousAmount" itemSubjectRef="ItemDefinition_Integer" name="suspiciousAmount"/>
    <bpmn2:property id="alertScore" itemSubjectRef="ItemDefinition_Integer" name="alertScore"/>
    <bpmn2:property id="investigatorId" itemSubjectRef="ItemDefinition_String" name="investigatorId"/>
    <bpmn2:property id="evidenceCount" itemSubjectRef="ItemDefinition_Integer" name="evidenceCount"/>
    <bpmn2:property id="isFraudConfirmed" itemSubjectRef="ItemDefinition_Boolean" name="isFraudConfirmed"/>
    <bpmn2:property id="requiresLawEnforcement" itemSubjectRef="ItemDefinition_Boolean" name="requiresLawEnforcement"/>
    <bpmn2:property id="accountFrozen" itemSubjectRef="ItemDefinition_Boolean" name="accountFrozen"/>
    <bpmn2:property id="resolutionCode" itemSubjectRef="ItemDefinition_String" name="resolutionCode"/>
    <bpmn2:property id="statusCode" itemSubjectRef="ItemDefinition_String" name="statusCode"/>

    <!-- Start Event -->
    <bpmn2:startEvent id="StartEvent_1" name="Alert Triggered">
      <bpmn2:outgoing>SequenceFlow_1</bpmn2:outgoing>
    </bpmn2:startEvent>

    <!-- Triage Alert -->
    <bpmn2:scriptTask id="ScriptTask_1" name="Triage Alert" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>SequenceFlow_1</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_2</bpmn2:outgoing>
      <bpmn2:script>String id = "FRD-" + customerId + "-" + System.currentTimeMillis();
kcontext.setVariable("caseId", id);
boolean freeze = alertScore > 80;
kcontext.setVariable("accountFrozen", freeze);
kcontext.setVariable("statusCode", "TRIAGED");
System.out.println("Fraud alert triaged: " + id + " score: " + alertScore + " freeze: " + freeze);</bpmn2:script>
    </bpmn2:scriptTask>

    <!-- Gateway: Alert Score > 80? -->
    <bpmn2:exclusiveGateway id="Gateway_1" name="Freeze Account?" gatewayDirection="Diverging">
      <bpmn2:incoming>SequenceFlow_2</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_3</bpmn2:outgoing>
      <bpmn2:outgoing>SequenceFlow_4</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- Freeze Account -->
    <bpmn2:scriptTask id="ScriptTask_2" name="Freeze Account" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>SequenceFlow_3</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_5</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable("accountFrozen", true);
kcontext.setVariable("statusCode", "ACCOUNT_FROZEN");
System.out.println("Account frozen for customer " + customerId + " - alert score: " + alertScore);</bpmn2:script>
    </bpmn2:scriptTask>

    <!-- Merge Freeze -->
    <bpmn2:exclusiveGateway id="Gateway_2" name="Merge Freeze" gatewayDirection="Converging">
      <bpmn2:incoming>SequenceFlow_5</bpmn2:incoming>
      <bpmn2:incoming>SequenceFlow_4</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_6</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- Assign Investigator -->
    <bpmn2:userTask id="UserTask_1" name="Assign Investigator" drools:taskName="Assign Investigator">
      <bpmn2:incoming>SequenceFlow_6</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_7</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="DataInput_1" name="TaskName" drools:dtype="Object"/>
        <bpmn2:dataInput id="DataInput_2" name="GroupId" drools:dtype="Object"/>
        <bpmn2:dataOutput id="DataOutput_1" name="investigatorId" drools:dtype="Object"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>DataInput_1</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>DataInput_2</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>DataOutput_1</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_1</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">Fraud Case Assignment</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_1</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_2</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">fraud-team</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_2</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>DataOutput_1</bpmn2:sourceRef>
        <bpmn2:targetRef>investigatorId</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>

    <!-- Gather Evidence -->
    <bpmn2:userTask id="UserTask_2" name="Gather Evidence" drools:taskName="Gather Evidence">
      <bpmn2:incoming>SequenceFlow_7</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_8</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="DataInput_3" name="TaskName" drools:dtype="Object"/>
        <bpmn2:dataInput id="DataInput_4" name="GroupId" drools:dtype="Object"/>
        <bpmn2:dataOutput id="DataOutput_2" name="evidenceCount" drools:dtype="Object"/>
        <bpmn2:dataOutput id="DataOutput_3" name="fraudConfirmed" drools:dtype="Object"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>DataInput_3</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>DataInput_4</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>DataOutput_2</bpmn2:dataOutputRefs>
          <bpmn2:dataOutputRefs>DataOutput_3</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_3</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">Evidence Gathering</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_3</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_4</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">investigators</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_4</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>DataOutput_2</bpmn2:sourceRef>
        <bpmn2:targetRef>evidenceCount</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>DataOutput_3</bpmn2:sourceRef>
        <bpmn2:targetRef>isFraudConfirmed</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:userTask>

    <!-- Analyze Patterns -->
    <bpmn2:scriptTask id="ScriptTask_3" name="Analyze Patterns" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>SequenceFlow_8</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_9</bpmn2:outgoing>
      <bpmn2:script>boolean lawEnforcement = Boolean.TRUE.equals(isFraudConfirmed) &amp;&amp; suspiciousAmount > 1000000;
kcontext.setVariable("requiresLawEnforcement", lawEnforcement);
kcontext.setVariable("statusCode", "ANALYZED");
System.out.println("Pattern analysis complete - fraud confirmed: " + isFraudConfirmed + ", law enforcement: " + lawEnforcement);</bpmn2:script>
    </bpmn2:scriptTask>

    <!-- Gateway: Fraud Confirmed? -->
    <bpmn2:exclusiveGateway id="Gateway_3" name="Fraud Confirmed?" gatewayDirection="Diverging">
      <bpmn2:incoming>SequenceFlow_9</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_10</bpmn2:outgoing>
      <bpmn2:outgoing>SequenceFlow_11</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- Gateway: Notify Law Enforcement? -->
    <bpmn2:exclusiveGateway id="Gateway_4" name="Law Enforcement?" gatewayDirection="Diverging">
      <bpmn2:incoming>SequenceFlow_10</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_12</bpmn2:outgoing>
      <bpmn2:outgoing>SequenceFlow_13</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- File SAR -->
    <bpmn2:userTask id="UserTask_3" name="File SAR" drools:taskName="File SAR">
      <bpmn2:incoming>SequenceFlow_12</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_14</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="DataInput_5" name="TaskName" drools:dtype="Object"/>
        <bpmn2:dataInput id="DataInput_6" name="GroupId" drools:dtype="Object"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>DataInput_5</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>DataInput_6</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet/>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_5</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">File Suspicious Activity Report</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_5</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>DataInput_6</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">compliance</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">DataInput_6</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
    </bpmn2:userTask>

    <!-- Merge SAR -->
    <bpmn2:exclusiveGateway id="Gateway_5" name="Merge SAR" gatewayDirection="Converging">
      <bpmn2:incoming>SequenceFlow_14</bpmn2:incoming>
      <bpmn2:incoming>SequenceFlow_13</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_15</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- Close Case (no fraud) -->
    <bpmn2:scriptTask id="ScriptTask_4" name="Close Case" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>SequenceFlow_11</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_16</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable("resolutionCode", "NO_FRAUD");
kcontext.setVariable("accountFrozen", false);
kcontext.setVariable("statusCode", "CLOSED_NO_FRAUD");
System.out.println("Case " + caseId + " closed - no fraud confirmed");</bpmn2:script>
    </bpmn2:scriptTask>

    <!-- Merge Fraud Decision -->
    <bpmn2:exclusiveGateway id="Gateway_6" name="Merge Final" gatewayDirection="Converging">
      <bpmn2:incoming>SequenceFlow_15</bpmn2:incoming>
      <bpmn2:incoming>SequenceFlow_16</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_17</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>

    <!-- Resolution Actions -->
    <bpmn2:scriptTask id="ScriptTask_5" name="Resolution Actions" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>SequenceFlow_17</bpmn2:incoming>
      <bpmn2:outgoing>SequenceFlow_18</bpmn2:outgoing>
      <bpmn2:script>if (resolutionCode == null) {
    kcontext.setVariable("resolutionCode", Boolean.TRUE.equals(requiresLawEnforcement) ? "SAR_FILED" : "FRAUD_CONFIRMED");
}
kcontext.setVariable("statusCode", "RESOLVED");
System.out.println("Case " + caseId + " resolved with code: " + resolutionCode);</bpmn2:script>
    </bpmn2:scriptTask>

    <!-- End Event -->
    <bpmn2:endEvent id="EndEvent_1" name="Case Closed">
      <bpmn2:incoming>SequenceFlow_18</bpmn2:incoming>
    </bpmn2:endEvent>

    <!-- Sequence Flows -->
    <bpmn2:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="ScriptTask_1"/>
    <bpmn2:sequenceFlow id="SequenceFlow_2" sourceRef="ScriptTask_1" targetRef="Gateway_1"/>
    <bpmn2:sequenceFlow id="SequenceFlow_3" name="Yes" sourceRef="Gateway_1" targetRef="ScriptTask_2">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return alertScore > 80;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_4" name="No" sourceRef="Gateway_1" targetRef="Gateway_2">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return alertScore &lt;= 80;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_5" sourceRef="ScriptTask_2" targetRef="Gateway_2"/>
    <bpmn2:sequenceFlow id="SequenceFlow_6" sourceRef="Gateway_2" targetRef="UserTask_1"/>
    <bpmn2:sequenceFlow id="SequenceFlow_7" sourceRef="UserTask_1" targetRef="UserTask_2"/>
    <bpmn2:sequenceFlow id="SequenceFlow_8" sourceRef="UserTask_2" targetRef="ScriptTask_3"/>
    <bpmn2:sequenceFlow id="SequenceFlow_9" sourceRef="ScriptTask_3" targetRef="Gateway_3"/>
    <bpmn2:sequenceFlow id="SequenceFlow_10" name="Fraud" sourceRef="Gateway_3" targetRef="Gateway_4">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return Boolean.TRUE.equals(isFraudConfirmed);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_11" name="No Fraud" sourceRef="Gateway_3" targetRef="ScriptTask_4">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return !Boolean.TRUE.equals(isFraudConfirmed);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_12" name="Yes" sourceRef="Gateway_4" targetRef="UserTask_3">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return requiresLawEnforcement;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_13" name="No" sourceRef="Gateway_4" targetRef="Gateway_5">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return !requiresLawEnforcement;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="SequenceFlow_14" sourceRef="UserTask_3" targetRef="Gateway_5"/>
    <bpmn2:sequenceFlow id="SequenceFlow_15" sourceRef="Gateway_5" targetRef="Gateway_6"/>
    <bpmn2:sequenceFlow id="SequenceFlow_16" sourceRef="ScriptTask_4" targetRef="Gateway_6"/>
    <bpmn2:sequenceFlow id="SequenceFlow_17" sourceRef="Gateway_6" targetRef="ScriptTask_5"/>
    <bpmn2:sequenceFlow id="SequenceFlow_18" sourceRef="ScriptTask_5" targetRef="EndEvent_1"/>

  </bpmn2:process>

  <!-- Item Definitions -->
  <bpmn2:itemDefinition id="ItemDefinition_String" structureRef="java.lang.String"/>
  <bpmn2:itemDefinition id="ItemDefinition_Integer" structureRef="java.lang.Integer"/>
  <bpmn2:itemDefinition id="ItemDefinition_Boolean" structureRef="java.lang.Boolean"/>

  <!-- Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="fraud-investigation">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="100" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ScriptTask_1" bpmnElement="ScriptTask_1">
        <dc:Bounds x="200" y="178" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_1" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="370" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ScriptTask_2" bpmnElement="ScriptTask_2">
        <dc:Bounds x="345" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_2" bpmnElement="Gateway_2" isMarkerVisible="true">
        <dc:Bounds x="520" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_UserTask_1" bpmnElement="UserTask_1">
        <dc:Bounds x="640" y="178" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_UserTask_2" bpmnElement="UserTask_2">
        <dc:Bounds x="800" y="178" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ScriptTask_3" bpmnElement="ScriptTask_3">
        <dc:Bounds x="960" y="178" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_3" bpmnElement="Gateway_3" isMarkerVisible="true">
        <dc:Bounds x="1130" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_4" bpmnElement="Gateway_4" isMarkerVisible="true">
        <dc:Bounds x="1130" y="80" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_UserTask_3" bpmnElement="UserTask_3">
        <dc:Bounds x="1250" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_5" bpmnElement="Gateway_5" isMarkerVisible="true">
        <dc:Bounds x="1400" y="80" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ScriptTask_4" bpmnElement="ScriptTask_4">
        <dc:Bounds x="1250" y="290" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_6" bpmnElement="Gateway_6" isMarkerVisible="true">
        <dc:Bounds x="1530" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_ScriptTask_5" bpmnElement="ScriptTask_5">
        <dc:Bounds x="1650" y="178" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="1820" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_1" bpmnElement="SequenceFlow_1">
        <di:waypoint x="136" y="218"/>
        <di:waypoint x="200" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_2" bpmnElement="SequenceFlow_2">
        <di:waypoint x="300" y="218"/>
        <di:waypoint x="370" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_3" bpmnElement="SequenceFlow_3">
        <di:waypoint x="395" y="193"/>
        <di:waypoint x="395" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_4" bpmnElement="SequenceFlow_4">
        <di:waypoint x="420" y="218"/>
        <di:waypoint x="520" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_5" bpmnElement="SequenceFlow_5">
        <di:waypoint x="445" y="120"/>
        <di:waypoint x="545" y="120"/>
        <di:waypoint x="545" y="193"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_6" bpmnElement="SequenceFlow_6">
        <di:waypoint x="570" y="218"/>
        <di:waypoint x="640" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_7" bpmnElement="SequenceFlow_7">
        <di:waypoint x="740" y="218"/>
        <di:waypoint x="800" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_8" bpmnElement="SequenceFlow_8">
        <di:waypoint x="900" y="218"/>
        <di:waypoint x="960" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_9" bpmnElement="SequenceFlow_9">
        <di:waypoint x="1060" y="218"/>
        <di:waypoint x="1130" y="218"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_10" bpmnElement="SequenceFlow_10">
        <di:waypoint x="1155" y="193"/>
        <di:waypoint x="1155" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_11" bpmnElement="SequenceFlow_11">
        <di:waypoint x="1180" y="218"/>
        <di:waypoint x="1215" y="218"/>
        <di:waypoint x="1215" y="330"/>
        <di:waypoint x="1250" y="330"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_SequenceFlow_12" bpmnElement="SequenceFlow_12">
        <di:waypoint x="1155" y="80"/>
